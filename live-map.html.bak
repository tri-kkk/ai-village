<script src="engine.classic.js"></script>
<script>
const DATA=JSON.parse(document.getElementById('data').textContent);
const SB="https://riqvjiiwjyynvhuynisv.supabase.co", ANON="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJpcXZqaWl3anl5bnZodXluaXN2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjE2MzgyNDIsImV4cCI6MjA3NzIxNDI0Mn0.HmTAFEMd-gEpl0PGb9t_j06QUJeSflTDZa0mnQcJDoY", WORLD="main";
const HDR={apikey:ANON, Authorization:'Bearer '+ANON};
const imgs={}; const im=new Image(); im.onload=()=>{imgs.tileset=im; boot();}; im.src='assets/tileset.png';
let v;
function boot(){
  v=new Village(document.getElementById('cv'),DATA,imgs,{});
  v.startRender();
  const hr=document.getElementById('hour');hr.oninput=()=>{const h=+hr.value;v.setHour(h);const lab=h<6||h>=20?'밤':h<8?'새벽':h<18?'낮':'저녁';document.getElementById('dnlabel').textContent=lab+' '+String(h).padStart(2,'0')+'시';};
  poll(); setInterval(poll,5000);
}
async function poll(){
  try{
    const live=await fetch(SB+'/rest/v1/village_live?world=eq.'+WORLD+'&select=*',{headers:HDR}).then(r=>r.json());
    const world=await fetch(SB+'/rest/v1/village_world?world=eq.'+WORLD+'&select=*',{headers:HDR}).then(r=>r.json());
    if(Array.isArray(live)&&live.length){
      v.applyLive(live);
      document.getElementById('status').textContent='● LIVE · 주민 '+live.length+'명';
      document.getElementById('feed').innerHTML=live.filter(a=>a.say||a.action).map(a=>'<div><span class="who" style="color:'+(V_COLORS[a.name]||"#fff")+'">'+a.name+'</span> <span style="color:#8b93a3">@'+a.place+'</span> '+(a.action||'')+(a.say?' — "'+a.say+'"':'')+'</div>').join('');
    } else { document.getElementById('status').textContent='○ 데이터 대기 (live.mjs 실행했나요?)'; }
    if(Array.isArray(world)&&world.length){ const w=world[0]; v.setEvent(w.event); document.getElementById('tick').textContent='T'+w.tick; const b=document.getElementById('banner'); if(w.event){b.style.display='block';b.textContent='📢 '+w.event;}else b.style.display='none'; }
  }catch(e){ document.getElementById('status').textContent='○ 연결 대기…'; }
}
</script></body></html>